# =============================================================================
# DocMigrate Frontend — Environment Variables
# Copy this file to .env.local and fill in the values for your environment.
# NEVER commit .env.local to version control.
# =============================================================================

# API base URL (consumed by src/config/api.ts via import.meta.env.VITE_API_URL)
VITE_API_URL=http://localhost:5029

# Keycloak — Identity Provider
VITE_KEYCLOAK_URL=https://auth-dev.invoicy.com.br
VITE_KEYCLOAK_REALM=Migrate
VITE_KEYCLOAK_CLIENT_ID=docmigrate-frontend

# Parent origin for iframe postMessage validation
VITE_PARENT_ORIGIN=https://bmscore.migrate.info
